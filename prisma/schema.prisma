generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                           String                        @id @default(cuid())
  email                        String                        @unique
  name                         String
  password                     String
  role                         Role                          @default(CLIENT)
  avatar                       String?
  plan                         String                        @default("Free")
  phone                        String?
  dob                          DateTime?
  timezone                     String                        @default("UTC")
  language                     String                        @default("en")
  xp                           Int                           @default(0)
  level                        Int                           @default(1)
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  therapistId                  String?
  clientCode                   String?                       @unique
  notificationPrefs            Json?
  privacyPrefs                 Json?
  twoFactorEnabled             Boolean                       @default(false)
  twoFactorSecret              String?
  twoFactorFailedAttempts      Int                           @default(0)
  twoFactorLockedUntil         DateTime?
  hasOnboarded                 Boolean                       @default(false)
  hasSeenClientTour            Boolean                       @default(true)
  peerMatchingOptIn            Boolean                       @default(false)
  lastDailyReminderSentAt      DateTime?
  lastMissionReminderSentAt    DateTime?
  lastMoodReminderSentAt       DateTime?
  lastWeeklyDigestSentAt       DateTime?
  achievements                 Achievement[]
  communityReports             CommunityReport[]
  clientAppointments           Appointment[]                 @relation("ClientAppointments")
  assessmentResults            AssessmentResult[]
  communityPosts               CommunityPost[]
  clientConversations          Conversation[]                @relation("ClientConversations")
  courseProgress               CourseProgress[]
  articleProgress              ArticleProgress[]
  groupMemberships             GroupMembership[]
  journalEntries               JournalEntry[]
  sentMessages                 Message[]
  missionCompletions           MissionCompletion[]
  moodEntries                  MoodEntry[]
  notifications                Notification[]
  postLikes                    PostLike[]
  postReplies                  PostReply[]                   @relation("PostReplyAuthor")
  therapistProfile             Therapist?                    @relation("TherapistUser")
  therapistGroupInvites        TherapistGroupInvite[]        @relation("TherapistGroupInviteUser")
  therapistGroupMemberships    TherapistGroupMembership[]    @relation("TherapistGroupMemberUser")
  therapistGroupPosts          TherapistGroupPost[]          @relation("TherapistGroupPostAuthor")
  therapistGroupPostLikes      TherapistGroupPostLike[]      @relation("TherapistGroupPostLikeUser")
  therapistGroupPostReplies    TherapistGroupPostReply[]     @relation("TherapistGroupPostReplyAuthor")
  receivedMissions             MissionAssignment[]           @relation("ClientMissionAssignments")
  assignedTherapist            Therapist?                    @relation("TherapistClients", fields: [therapistId], references: [id], onDelete: SetNull)
  clinicalNotes                ClinicalNote[]                @relation("ClientClinicalNotes")
  treatmentPlans               TreatmentPlan[]               @relation("ClientTreatmentPlans")
  courseEnrollments            CourseEnrollment[]            @relation("ClientCourseEnrollments")
  therapistGroupPostReplyLikes TherapistGroupPostReplyLike[] @relation("TherapistGroupPostReplyLikeUser")
  challengeParticipations      ChallengeParticipant[]
  adminAuditLogs               AdminAuditLog[]
  safetyPlan                   SafetyPlan?
  riskFlags                    RiskFlag[]
  waitlistEntries              WaitlistEntry[]
  backupCodes                  BackupCode[]
  clientIntake                 ClientIntake?
}

model Therapist {
  id                  String                      @id @default(cuid())
  userId              String                      @unique
  title               String
  specializations     String[]
  bio                 String?
  approach            String?
  yearsOfExperience   Int?
  education           String[]                    @default([])
  languages           String[]                    @default([])
  licenseNumber       String?
  rating              Float                       @default(0)
  totalSessions       Int                         @default(0)
  activeClients       Int                         @default(0)
  pendingAppointments Int                         @default(0)
  pendingMessages     Int                         @default(0)
  verificationStatus  TherapistVerificationStatus @default(pending)
  verifiedAt          DateTime?
  maxClients          Int?
  professionType      ProfessionType?
  gender              String?
  profileCompleted    Boolean                     @default(true)
  ageGroupsServed     String[]                    @default([])
  modalities          String[]                    @default([])
  createdAt           DateTime                    @default(now())
  appointments        Appointment[]               @relation("TherapistAppointments")
  conversations       Conversation[]              @relation("TherapistConversations")
  missions            Mission[]
  user                User                        @relation("TherapistUser", fields: [userId], references: [id], onDelete: Cascade)
  groups              TherapistGroup[]
  clients             User[]                      @relation("TherapistClients")
  clinicalNotes       ClinicalNote[]
  treatmentPlans      TreatmentPlan[]
  courseEnrollments   CourseEnrollment[]
  availabilitySlots   AvailabilitySlot[]
  waitlistEntries     WaitlistEntry[]
}

model MoodEntry {
  id        String   @id @default(cuid())
  userId    String
  score     Int
  label     String
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model JournalEntry {
  id           String   @id @default(cuid())
  userId       String
  title        String
  content      String
  mood         Int
  emotions     String[]
  sleepQuality Int?
  triggers     String[] @default([])
  wordCount    Int      @default(0)
  type         String   @default("text")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Course {
  id          String           @id @default(cuid())
  title       String
  instructor  String
  category    String
  level       String           @default("Beginner")
  tags        String[]         @default([])
  enrolled    Int              @default(0)
  description String?
  duration    String?
  lessonCount Int              @default(0)
  rating      Float            @default(0)
  thumbnail   String?
  color       String?
  published   Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  lessons     Lesson[]
  progress    CourseProgress[]
}

model Lesson {
  id           String           @id @default(cuid())
  courseId     String
  module       String
  order        Int
  title        String
  type         LessonType
  duration     String           @default("5 min")
  content      String?
  videoUrl     String?
  audioUrl     String?
  exerciseType String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  course       Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions    QuizQuestion[]
  progress     CourseProgress[]

  @@index([courseId, order])
}

model QuizQuestion {
  id          String   @id @default(cuid())
  lessonId    String
  order       Int
  question    String
  options     String[]
  correct     Int
  explanation String   @default("")
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId, order])
}

model CourseProgress {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  lessonId  String
  completed Boolean  @default(false)
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, lessonId])
  @@index([userId, courseId])
}

model Article {
  id          String            @id @default(cuid())
  slug        String            @unique
  title       String
  category    String
  summary     String
  readTime    String            @default("5 min")
  icon        String            @default("📄")
  color       String            @default("bg-sage-100")
  tags        String[]          @default([])
  published   Boolean           @default(true)
  order       Int               @default(0)
  blocks      Json
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  progress    ArticleProgress[]

  @@index([category])
}

model ArticleProgress {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  completed Boolean  @default(false)
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
  @@index([userId])
}

model AssessmentResult {
  id            String   @id @default(cuid())
  userId        String
  assessmentId  String
  score         Int
  label         String
  answers       Json
  safetyFlagged Boolean  @default(false)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, assessmentId])
}

model SafetyPlan {
  id                   String   @id @default(cuid())
  userId               String   @unique
  warningSigns         String[] @default([])
  copingStrategies     String[] @default([])
  distractionContacts  Json     @default("[]")
  supportContacts      Json     @default("[]")
  professionalContacts Json     @default("[]")
  safeEnvironmentSteps String[] @default([])
  sharedWithTherapist  Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RiskFlag {
  id               String    @id @default(cuid())
  userId           String
  source           String
  sourceId         String
  severity         String
  detail           String
  status           String    @default("open")
  acknowledgedAt   DateTime?
  acknowledgedById String?
  createdAt        DateTime  @default(now())
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model Mission {
  id           String              @id @default(cuid())
  title        String
  description  String
  category     String
  duration     Int
  xp           Int                 @default(10)
  recurring    Boolean             @default(true)
  activityType String              @default("generic")
  therapistId  String?
  createdAt    DateTime            @default(now())
  therapist    Therapist?          @relation(fields: [therapistId], references: [id], onDelete: SetNull)
  completions  MissionCompletion[]
  assignments  MissionAssignment[]
  attachments  MissionAttachment[]

  @@index([therapistId])
}

model MissionAttachment {
  id        String   @id @default(cuid())
  missionId String
  name      String
  size      Int
  mimeType  String
  url       String
  createdAt DateTime @default(now())
  mission   Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
}

model MissionAssignment {
  id         String   @id @default(cuid())
  missionId  String
  clientId   String
  assignedAt DateTime @default(now())
  mission    Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  client     User     @relation("ClientMissionAssignments", fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([missionId, clientId])
  @@index([clientId])
}

model MissionCompletion {
  id           String   @id @default(cuid())
  userId       String
  missionId    String
  completedAt  DateTime @default(now())
  responseData Json?
  mission      Mission  @relation(fields: [missionId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, missionId, completedAt])
}

model Achievement {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model SupportGroup {
  id          String            @id @default(cuid())
  name        String
  description String
  category    String
  icon        String
  color       String
  nextSession DateTime?
  createdAt   DateTime          @default(now())
  posts       CommunityPost[]
  memberships GroupMembership[]
}

model GroupMembership {
  id       String       @id @default(cuid())
  userId   String
  groupId  String
  joinedAt DateTime     @default(now())
  group    SupportGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model CommunityPost {
  id        String        @id @default(cuid())
  userId    String
  groupId   String?
  content   String
  anonymous Boolean       @default(false)
  pinned    Boolean       @default(false)
  flagged   Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  group     SupportGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     PostLike[]
  replies   PostReply[]

  @@index([groupId, createdAt])
}

model PostLike {
  id        String        @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model PostReply {
  id        String        @id @default(cuid())
  postId    String
  userId    String?
  content   String
  anonymous Boolean       @default(false)
  createdAt DateTime      @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User?         @relation("PostReplyAuthor", fields: [userId], references: [id])

  @@index([postId, createdAt])
}

model TherapistGroup {
  id          String                     @id @default(cuid())
  therapistId String
  name        String
  description String?
  category    String
  icon        String                     @default("💬")
  privacy     CommunityPrivacy           @default(open)
  status      CommunityStatus            @default(active)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  therapist   Therapist                  @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  invites     TherapistGroupInvite[]
  memberships TherapistGroupMembership[]
  posts       TherapistGroupPost[]

  @@index([therapistId, status])
}

model TherapistGroupMembership {
  id       String         @id @default(cuid())
  groupId  String
  clientId String
  joinedAt DateTime       @default(now())
  client   User           @relation("TherapistGroupMemberUser", fields: [clientId], references: [id], onDelete: Cascade)
  group    TherapistGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, clientId])
}

model TherapistGroupInvite {
  id       String         @id @default(cuid())
  groupId  String
  clientId String
  sentAt   DateTime       @default(now())
  accepted Boolean        @default(false)
  client   User           @relation("TherapistGroupInviteUser", fields: [clientId], references: [id], onDelete: Cascade)
  group    TherapistGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, clientId])
}

model TherapistGroupPost {
  id        String                    @id @default(cuid())
  groupId   String
  authorId  String
  content   String
  pinned    Boolean                   @default(false)
  flagged   Boolean                   @default(false)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  author    User                      @relation("TherapistGroupPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  group     TherapistGroup            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  likes     TherapistGroupPostLike[]
  replies   TherapistGroupPostReply[]

  @@index([groupId, pinned, createdAt])
}

model TherapistGroupPostLike {
  id        String             @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime           @default(now())
  post      TherapistGroupPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User               @relation("TherapistGroupPostLikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model TherapistGroupPostReply {
  id        String                        @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime                      @default(now())
  author    User                          @relation("TherapistGroupPostReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  post      TherapistGroupPost            @relation(fields: [postId], references: [id], onDelete: Cascade)
  likes     TherapistGroupPostReplyLike[]

  @@index([postId, createdAt])
}

model TherapistGroupPostReplyLike {
  id        String                  @id @default(cuid())
  replyId   String
  userId    String
  createdAt DateTime                @default(now())
  reply     TherapistGroupPostReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user      User                    @relation("TherapistGroupPostReplyLikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([replyId, userId])
}

model Appointment {
  id             String            @id @default(cuid())
  clientId       String
  therapistId    String
  date           DateTime
  duration       Int               @default(50)
  type           AppointmentType   @default(video)
  status         AppointmentStatus @default(pending)
  notes          String?
  isNew          Boolean           @default(false)
  reminderSentAt DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  client         User              @relation("ClientAppointments", fields: [clientId], references: [id], onDelete: Cascade)
  therapist      Therapist         @relation("TherapistAppointments", fields: [therapistId], references: [id], onDelete: Cascade)
  videoSession   VideoSession?
  videoSignals   VideoSignal[]

  @@index([clientId, date])
  @@index([therapistId, date])
}

model VideoSession {
  id                String                 @id @default(cuid())
  appointmentId     String                 @unique
  status            VideoSessionStatus     @default(open)
  clientJoinedAt    DateTime?
  clientLeftAt      DateTime?
  therapistJoinedAt DateTime?
  therapistLeftAt   DateTime?
  endedAt           DateTime?
  endedReason       VideoSessionEndReason?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  appointment       Appointment            @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([status, updatedAt])
}

model VideoSignal {
  id            String          @id @default(cuid())
  appointmentId String
  senderId      String
  type          VideoSignalType
  payload       Json
  createdAt     DateTime        @default(now())
  deliveredAt   DateTime?
  appointment   Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId, deliveredAt, createdAt])
}

model Conversation {
  id          String    @id @default(cuid())
  clientId    String
  therapistId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      User      @relation("ClientConversations", fields: [clientId], references: [id], onDelete: Cascade)
  therapist   Therapist @relation("TherapistConversations", fields: [therapistId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@unique([clientId, therapistId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  fromUserId     String
  text           String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  from           User         @relation(fields: [fromUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  icon      String?
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model ClinicalNote {
  id                 String      @id @default(cuid())
  therapistId        String
  clientId           String
  date               DateTime
  sessionType        SessionType @default(individual)
  content            String
  noteFormat         String      @default("freeform")
  subjective         String?
  objective          String?
  clinicalAssessment String?
  affect             String?
  riskLevel          RiskLevel   @default(low)
  nextSteps          String?
  tags               String[]    @default([])
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  therapist          Therapist   @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  client             User        @relation("ClientClinicalNotes", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([therapistId, clientId, date])
}

model TreatmentPlan {
  id                String    @id @default(cuid())
  therapistId       String
  clientId          String
  diagnosis         String    @default("")
  approach          String    @default("")
  frequency         String    @default("")
  shortTermGoals    String    @default("")
  longTermGoals     String    @default("")
  phase             String    @default("")
  riskLevel         RiskLevel @default(low)
  safetyPlan        Boolean   @default(false)
  emergencyContacts Boolean   @default(false)
  lastAssessed      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  therapist         Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  client            User      @relation("ClientTreatmentPlans", fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([therapistId, clientId])
}

model CourseEnrollment {
  id          String                 @id @default(cuid())
  therapistId String
  clientId    String
  courseName  String
  status      CourseEnrollmentStatus @default(in_progress)
  assignedAt  DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  therapist   Therapist              @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  client      User                   @relation("ClientCourseEnrollments", fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, courseName])
}

model AvailabilitySlot {
  id          String    @id @default(cuid())
  therapistId String
  day         String
  time        String
  createdAt   DateTime  @default(now())
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@unique([therapistId, day, time])
}

model WaitlistEntry {
  id          String    @id @default(cuid())
  therapistId String
  userId      String
  status      String    @default("waiting") // "waiting" | "resolved"
  createdAt   DateTime  @default(now())
  therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([therapistId, userId])
}

model BackupCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ClientIntake {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  concerns               String[] @default([])
  languagePreference     String?
  genderPreference       String?
  ageRange               String?
  priorTherapyExperience String?
  goals                  String?
  modalityPreference     String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CommunityReport {
  id         String                @id @default(cuid())
  targetId   String
  targetType String
  reporterId String
  reason     String
  status     CommunityReportStatus @default(open)
  createdAt  DateTime              @default(now())
  reporter   User                  @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([targetId])
  @@index([reporterId])
  @@index([status])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([adminId, createdAt])
}

model Challenge {
  id           String                 @id @default(cuid())
  title        String
  description  String
  category     String
  difficulty   String                 @default("Beginner")
  totalDays    Int
  xpReward     Int                    @default(50)
  activityType String                 @default("generic")
  createdAt    DateTime               @default(now())
  participants ChallengeParticipant[]
}

model ChallengeParticipant {
  id           String    @id @default(cuid())
  challengeId  String
  userId       String
  progress     Int       @default(0)
  joinedAt     DateTime  @default(now())
  lastLoggedAt DateTime?
  completedAt  DateTime?
  challenge    Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([userId])
}

enum Role {
  CLIENT
  THERAPIST
  ADMIN
}

enum AppointmentStatus {
